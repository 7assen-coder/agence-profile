if __name__ == '__main__':
    # Création des tables et initialisation des données de test
    with app.app_context():
        db.create_all()
        if Place.query.count() == 0:
            for i in range(1, 13):
                db.session.add(Place(numero_place=i))
            db.session.commit()

    # Lancement du thread de nettoyage
    threading.Thread(target=script_nettoyage, daemon=True).start()
    
    # Lancement du serveur (debug=False est préférable quand on utilise des threads de fond)
    app.run(debug=False, port=5001)
