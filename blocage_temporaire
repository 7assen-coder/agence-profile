import threading
import time
from datetime import datetime, timedelta
from flask import Flask, jsonify, request, render_template_string
from flask_sqlalchemy import SQLAlchemy

app = Flask(__name__)
# Utilisation d'un verrou pour éviter les accès concurrents sur SQLite/MySQL pendant les écritures
db_lock = threading.Lock()

# --- CONFIGURATION DB ---
# Note : Assurez-vous que la base 'transport_reservation' existe sur votre MySQL
app.config['SQLALCHEMY_DATABASE_URI'] = 'mysql+pymysql://root:@localhost/transport_reservation'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
db = SQLAlchemy(app)

# --- MODÈLES ---
class Place(db.Model):
    __tablename__ = 'places'
    id_place = db.Column(db.Integer, primary_key=True)
    numero_place = db.Column(db.Integer)
    status = db.Column(db.String(20), default='Disponible')

class Reservation(db.Model):
    __tablename__ = 'reservations'
    id_reservation = db.Column(db.Integer, primary_key=True, autoincrement=True)
    id_place = db.Column(db.Integer)
    statut = db.Column(db.Enum('en_attente', 'confirmee', 'annulee'), default='en_attente')
    expire_a = db.Column(db.DateTime)

# --- LOGIQUE DE NETTOYAGE (TIMER) ---
def script_nettoyage():
    """Vérifie chaque seconde si des réservations en attente ont expiré."""
    while True:
        time.sleep(1)
        with app.app_context():
            with db_lock:
                try:
                    now = datetime.now()
                    # On récupère les réservations qui ont dépassé le temps 'expire_a'
                    expirees = Reservation.query.filter(
                        Reservation.statut == 'en_attente', 
                        Reservation.expire_a <= now
                    ).all()
                    
                    for r in expirees:
                        r.statut = 'annulee'
                        p = Place.query.get(r.id_place)
                        if p and p.status == 'Bloquée':
                            p.status = 'Disponible'
                    db.session.commit()
                except Exception as e:
                    print(f"Erreur nettoyage: {e}")
                    db.session.rollback()

# --- ROUTES API ---
@app.route('/')
def index():
    return render_template_string(HTML_UI)

@app.route('/api/etat')
def get_etat():
    with db_lock:
        places = Place.query.all()
        data = []
        now = datetime.now()
        for p in places:
            reste = 0
            # On cherche la réservation active pour cette place
            res = Reservation.query.filter_by(id_place=p.id_place, statut='en_attente').first()
            if res:
                diff = res.expire_a - now
                reste = max(0, int(diff.total_seconds()))
            
            data.append({
                'id': p.id_place, 
                'n': p.numero_place, 
                's': p.status, 
                'r': reste
            })
        return jsonify(data)

@app.route('/api/bloquer', methods=['POST'])
def bloquer():
    pid = request.json.get('id')
    with db_lock:
        try:
            p = Place.query.get(pid)
            if p and p.status == 'Disponible':
                fin = datetime.now() + timedelta(seconds=30)
                nouvelle_res = Reservation(id_place=pid, expire_a=fin, statut='en_attente')
                db.session.add(nouvelle_res)
                p.status = 'Bloquée'
                db.session.commit()
                return jsonify({'ok': True})
        except Exception as e:
            db.session.rollback()
    return jsonify({'ok': False})

@app.route('/api/payer', methods=['POST'])
def payer():
    pid = request.json.get('id')
    with db_lock:
        try:
            # On récupère la dernière réservation en attente pour cette place
            r = Reservation.query.filter_by(id_place=pid, statut='en_attente').first()
            p = Place.query.get(pid)
            if r and p:
                r.statut = 'confirmee'
                p.status = 'Réservée'
                db.session.commit()
                return jsonify({'ok': True})
        except Exception as e:
            db.session.rollback()
    return jsonify({'ok': False})

