FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-prod
JWT_SECRET_KEY=change-me-jwt-secret

# Port HTTP (défaut dans run.py : 5001 — évite le conflit avec AirPlay sur macOS qui utilise souvent 5000)
# FLASK_PORT=5001

# Optionnel : remplace la connexion MySQL (ex. SQLite en dev local)
# SQLALCHEMY_DATABASE_URI=sqlite:////chemin/absolu/instance/agence.db

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=trajets_saas

# Upload
UPLOAD_FOLDER=uploads/logos
MAX_CONTENT_MB=2
